// Simplex example: Fibonacci
// Run with: node bin/simplex.js examples/fibonacci.sim

fn fib(n: Number) -> Number {
  if n <= 0 {
    return 0;
  }
  if n == 1 {
    return 1;
  }
  fib(n - 1) + fib(n - 2)
}

// Print first 15 Fibonacci numbers using recursion
fn print_fib(i: Number, max: Number) -> Unit {
  if i >= max {
    return;
  }
  let f: Number = fib(i);
  print("fib(" + to_string(i) + ") = " + to_string(f));
  print_fib(i + 1, max);
}

print_fib(0, 15);
