fn draw() {
  canvas_clear()

  canvas_set_fill_color("#FF6B6B")
  canvas_fill_rect(50, 50, 200, 150)

  canvas_set_fill_color("#4ECDC4")
  canvas_fill_rect(300, 50, 200, 150)

  canvas_set_fill_color("white")
  canvas_set_font("bold 48px sans-serif")
  canvas_fill_text("Simplex", 120, 300)
}

draw()