fn get_cards_for_char(char: String) -> List<Number> {
  let mut result: List<Number> = [];
  let mut i: Number = 0;
  while i < all_cards.len {
    let card: CardConfig = list_get(all_cards, i).value;
    if card.char == char or card.char == "common" {
      if card.id < 18 {
        result = append(result, card.id);
      };
    };
    i = i + 1;
  };
  result
}

fn shuffle(deck: List<Number>) -> List<Number> {
  let mut result: List<Number> = deck;
  let n: Number = result.len;
  let mut i: Number = 0;
  while i < n * 3 {
    let a: Number = random(n);
    let b: Number = random(n);
    if a != b {
      let va: Number = list_get(result, a).value;
      let vb: Number = list_get(result, b).value;
      result = list_remove_at(result, max(a, b));
      result = list_remove_at(result, min(a, b));
      result = append(result, va);
      result = append(result, vb);
    };
    i = i + 1;
  };
  result
}

fn draw_one_card(hand: List<Number>, deck: List<Number>, discard: List<Number>) -> DrawResult {
  if deck.len == 0 {
    if discard.len == 0 {
      { hand: hand, deck: deck, discard: discard }
    } else {
      let reshuffled: List<Number> = shuffle(discard);
      let card: Number = list_get(reshuffled, 0).value;
      let rest: List<Number> = list_remove_at(reshuffled, 0);
      { hand: append(hand, card), deck: rest, discard: [] }
    }
  } else {
    let card: Number = list_get(deck, 0).value;
    let rest: List<Number> = list_remove_at(deck, 0);
    { hand: append(hand, card), deck: rest, discard: discard }
  }
}

fn draw_n(n: Number, hand: List<Number>, deck: List<Number>, discard: List<Number>) -> DrawResult {
  let mut h: List<Number> = hand;
  let mut d: List<Number> = deck;
  let mut ds: List<Number> = discard;
  let mut i: Number = 0;
  while i < n {
    let dr: DrawResult = draw_one_card(h, d, ds);
    h = dr.hand;
    d = dr.deck;
    ds = dr.discard;
    if h == hand and d == deck and ds == discard {
      i = n;
    };
    i = i + 1;
  };
  { hand: h, deck: d, discard: ds }
}

fn heal_char(hp: Number, max_hp: Number, amount: Number) -> Number {
  if hp + amount > max_hp { max_hp } else { hp + amount }
}

fn apply_damage(hp: Number, shield: Number, dmg: Number) -> DamageResult {
  if shield >= dmg {
    { hp: hp, shield: shield - dmg }
  } else {
    let remaining: Number = dmg - shield;
    { hp: hp - remaining, shield: 0 }
  }
}

fn add_log(log: List<String>, msg: String) -> List<String> {
  if log.len >= 5 {
    append(list_remove_at(log, 0), msg)
  } else {
    append(log, msg)
  }
}

let mut state: GameState = {
  screen: "title", phase: "", turn: 0,
  player_name: "", player_char: "",
  player_hp: 20, player_max_hp: 20,
  player_mana: 0, player_max_mana: 0,
  player_shield: 0, player_deck: [], player_hand: [], player_discard: [],
  enemy_name: "", enemy_char: "",
  enemy_hp: 20, enemy_max_hp: 20,
  enemy_mana: 0, enemy_max_mana: 0,
  enemy_shield: 0, enemy_deck: [], enemy_hand: [], enemy_discard: [],
  selected_card: -1, log: [], winner: ""
};

fn try_play_card(idx: Number) -> Unit {
  let hand: List<Number> = state.player_hand;
  if idx >= 0 and idx < hand.len {
    let card_id: Number = list_get(hand, idx).value;
    let card: CardConfig = list_get(all_cards, card_id).value;
    if state.player_mana >= card.cost {
      state = record_update(state, "player_mana", state.player_mana - card.cost);
      state = record_update(state, "player_hand", list_remove_at(hand, idx));
      state = record_update(state, "player_discard", append(state.player_discard, card_id));
      if card.effect_type == "damage" {
        let dmg: Number = card.effect_value;
        let dr: DamageResult = apply_damage(state.enemy_hp, state.enemy_shield, dmg);
        state = record_update(state, "enemy_hp", dr.hp);
        state = record_update(state, "enemy_shield", dr.shield);
        state = record_update(state, "log", add_log(state.log, concat("你对敌人造成", concat(to_string(dmg), "点伤害！"))));
      } elif card.effect_type == "shield" {
        let shield_amt: Number = card.effect_value;
        state = record_update(state, "player_shield", state.player_shield + shield_amt);
        state = record_update(state, "log", add_log(state.log, concat("你获得了", concat(to_string(shield_amt), "点护盾！"))));
      } elif card.effect_type == "heal" {
        let heal_amt: Number = card.effect_value;
        let new_hp: Number = heal_char(state.player_hp, state.player_max_hp, heal_amt);
        state = record_update(state, "player_hp", new_hp);
        state = record_update(state, "log", add_log(state.log, concat("你恢复了", concat(to_string(heal_amt), "点HP！"))));
      } elif card.effect_type == "mana" {
        let mana_amt: Number = card.effect_value;
        state = record_update(state, "player_mana", state.player_mana + mana_amt);
        state = record_update(state, "log", add_log(state.log, concat("恢复了", concat(to_string(mana_amt), "点魔力！"))));
      } elif card.effect_type == "draw" {
        let draw_n_val: Number = card.effect_value;
        let dr_res: DrawResult = draw_n(draw_n_val, state.player_hand, state.player_deck, state.player_discard);
        state = record_update(state, "player_hand", dr_res.hand);
        state = record_update(state, "player_deck", dr_res.deck);
        state = record_update(state, "player_discard", dr_res.discard);
        state = record_update(state, "log", add_log(state.log, concat("抽了", concat(to_string(draw_n_val), "张牌！"))));
      };
      if state.enemy_hp <= 0 {
        state = record_update(state, "enemy_hp", 0);
        state = record_update(state, "winner", "player");
        state = record_update(state, "screen", "game-over");
        state = record_update(state, "phase", "done");
        state = record_update(state, "log", add_log(state.log, "你获得了胜利！"));
      };
    } else {
      state = record_update(state, "log", add_log(state.log, "魔力不足！"));
    };
  };
  state = record_update(state, "selected_card", -1);
}

fn enemy_turn_ai() -> Unit {
  let mut hand: List<Number> = state.enemy_hand;
  let mut deck: List<Number> = state.enemy_deck;
  let mut discard: List<Number> = state.enemy_discard;
  let mut mana: Number = state.enemy_mana;
  let mut hp: Number = state.enemy_hp;
  let mut shield: Number = state.enemy_shield;
  let mut player_hp: Number = state.player_hp;
  let mut player_shield: Number = state.player_shield;
  let mut log: List<String> = state.log;

  if deck.len == 0 and discard.len > 0 {
    deck = shuffle(discard);
    discard = [];
  };
  if deck.len > 0 {
    let card_id: Number = list_get(deck, 0).value;
    deck = list_remove_at(deck, 0);
    hand = append(hand, card_id);
  };

  let mut attempts: Number = 0;
  while attempts < 20 and hand.len > 0 {
    let card_idx: Number = random(hand.len);
    let cid: Number = list_get(hand, card_idx).value;
    let card: CardConfig = list_get(all_cards, cid).value;
    if mana >= card.cost {
      mana = mana - card.cost;
      hand = list_remove_at(hand, card_idx);
      discard = append(discard, cid);
      if card.effect_type == "damage" {
        let dmg: Number = card.effect_value;
        let dr: DamageResult = apply_damage(player_hp, player_shield, dmg);
        player_hp = dr.hp;
        player_shield = dr.shield;
        log = add_log(log, concat("敌人对你造成", concat(to_string(dmg), "点伤害！")));
      } elif card.effect_type == "shield" {
        shield = shield + card.effect_value;
        log = add_log(log, "敌人获得了护盾！");
      } elif card.effect_type == "heal" {
        hp = heal_char(hp, state.enemy_max_hp, card.effect_value);
        log = add_log(log, "敌人恢复了HP！");
      } elif card.effect_type == "mana" {
        mana = mana + card.effect_value;
        log = add_log(log, "敌人恢复了魔力！");
      } elif card.effect_type == "draw" {
        let mut di: Number = 0;
        while di < card.effect_value {
          let dr2: DrawResult = draw_one_card(hand, deck, discard);
          hand = dr2.hand;
          deck = dr2.deck;
          discard = dr2.discard;
          di = di + 1;
        };
        log = add_log(log, "敌人抽了牌！");
      };
    };
    attempts = attempts + 1;
  };

  state = record_update(state, "enemy_hand", hand);
  state = record_update(state, "enemy_deck", deck);
  state = record_update(state, "enemy_discard", discard);
  state = record_update(state, "enemy_mana", mana);
  state = record_update(state, "enemy_hp", hp);
  state = record_update(state, "enemy_shield", shield);
  state = record_update(state, "player_hp", player_hp);
  state = record_update(state, "player_shield", player_shield);
  state = record_update(state, "log", log);

  if player_hp <= 0 {
    state = record_update(state, "player_hp", 0);
    state = record_update(state, "winner", "enemy");
    state = record_update(state, "screen", "game-over");
    state = record_update(state, "phase", "done");
    state = record_update(state, "log", add_log(state.log, "你被击败了..."));
  };
}

