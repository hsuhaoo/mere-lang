type CardConfig = {
  id: Number, name: String, desc: String, cost: Number,
  card_type: String, char: String,
  effect_type: String, effect_value: Number
};

type GameState = {
  screen: String, phase: String, turn: Number,
  player_name: String, player_char: String,
  player_hp: Number, player_max_hp: Number,
  player_mana: Number, player_max_mana: Number,
  player_shield: Number, player_deck: List<Number>,
  player_hand: List<Number>, player_discard: List<Number>,
  enemy_name: String, enemy_char: String,
  enemy_hp: Number, enemy_max_hp: Number,
  enemy_mana: Number, enemy_max_mana: Number,
  enemy_shield: Number, enemy_deck: List<Number>,
  enemy_hand: List<Number>, enemy_discard: List<Number>,
  selected_card: Number,
  log: List<String>, winner: String
};

type DrawResult = { hand: List<Number>, deck: List<Number>, discard: List<Number> };
type DamageResult = { hp: Number, shield: Number };

