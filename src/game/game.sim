fn draw_hp_bar(x: Number, y: Number, w: Number, h: Number, cur: Number, max: Number, color: String) -> Unit {
  let pct: Number = if max > 0 { cur / max } else { 0 };
  canvas_set_fill_color("#333333");
  canvas_fill_rect(x, y, w, h);
  canvas_set_fill_color(color);
  if pct > 0 {
    canvas_fill_rect(x, y, w * pct, h);
  };
  canvas_set_fill_color("#ffffff");
  canvas_set_font("14px sans-serif");
  canvas_set_text_align("center");
  canvas_fill_text(concat(to_string(cur), concat("/", to_string(max))), x + w / 2, y + h / 2 + 5);
  canvas_set_text_align("left");
}

fn draw_card_ui(card_id: Number, x: Number, y: Number, w: Number, h: Number, selected: Boolean, is_enemy: Boolean) -> Unit {
  let card: CardConfig = list_get(all_cards, card_id).value;
  if selected {
    canvas_set_fill_color("#ffd700");
    canvas_fill_rect(x - 2, y - 2, w + 4, h + 4);
  };
  if is_enemy {
    canvas_set_fill_color("#2d1b2d");
  } else {
    canvas_set_fill_color("#16213e");
  };
  canvas_fill_rect(x, y, w, h);
  canvas_set_fill_color("#ffffff");
  canvas_set_font("bold 12px sans-serif");
  canvas_set_text_align("center");
  canvas_fill_text(card.name, x + w / 2, y + 18);
  canvas_set_fill_color("#aaaaaa");
  canvas_set_font("10px sans-serif");
  canvas_fill_text(card.desc, x + w / 2, y + 36);
  canvas_set_fill_color("#e94560");
  canvas_set_font("bold 12px sans-serif");
  canvas_fill_text(concat("费用:", to_string(card.cost)), x + w / 2, y + 54);
  if card.effect_type == "damage" {
    canvas_set_fill_color("#ff4444");
    canvas_fill_text(concat("伤害:", to_string(card.effect_value)), x + w / 2, y + 74);
  } elif card.effect_type == "shield" {
    canvas_set_fill_color("#4488ff");
    canvas_fill_text(concat("护盾:", to_string(card.effect_value)), x + w / 2, y + 74);
  } elif card.effect_type == "heal" {
    canvas_set_fill_color("#44ff44");
    canvas_fill_text(concat("回复:", to_string(card.effect_value)), x + w / 2, y + 74);
  } else {
    canvas_set_fill_color("#ffaa44");
    canvas_fill_text(card.effect_type, x + w / 2, y + 74);
  };
  canvas_set_text_align("left");
}

fn render_game_screen() -> Unit {
  render_bg();

  canvas_set_fill_color("#e94560");
  canvas_set_font("16px sans-serif");
  canvas_set_text_align("center");
  canvas_fill_text(concat("第", concat(to_string(state.turn), "回合")), 400, 20);

  canvas_draw_image(get_char_img(state.enemy_char), 20, 30, 50, 60);
  canvas_set_fill_color("#ffffff");
  canvas_set_font("bold 16px sans-serif");
  canvas_set_text_align("left");
  canvas_fill_text(concat(state.enemy_name, concat(" [", concat(state.enemy_char, "]"))), 80, 48);
  draw_hp_bar(80, 58, 250, 18, state.enemy_hp, state.enemy_max_hp, "#ff4444");
  canvas_set_fill_color("#4488ff");
  canvas_set_font("13px sans-serif");
  canvas_fill_text(concat("魔力:", concat(to_string(state.enemy_mana), concat("/", to_string(state.enemy_max_mana)))), 370, 73);
  if state.enemy_shield > 0 {
    canvas_set_fill_color("#44aaff");
    canvas_fill_text(concat("护盾:", to_string(state.enemy_shield)), 520, 73);
  };

  canvas_draw_image(get_char_img(state.player_char), 20, 270, 50, 60);
  canvas_set_fill_color("#ffffff");
  canvas_set_font("bold 16px sans-serif");
  canvas_fill_text(concat(state.player_name, concat(" [", concat(state.player_char, "]"))), 80, 288);
  draw_hp_bar(80, 298, 250, 18, state.player_hp, state.player_max_hp, "#44ff44");
  canvas_set_fill_color("#4488ff");
  canvas_set_font("13px sans-serif");
  canvas_fill_text(concat("魔力:", concat(to_string(state.player_mana), concat("/", to_string(state.player_max_mana)))), 370, 313);
  if state.player_shield > 0 {
    canvas_set_fill_color("#44aaff");
    canvas_fill_text(concat("护盾:", to_string(state.player_shield)), 520, 313);
  };

  canvas_set_fill_color("#e94560");
  canvas_fill_rect(620, 460, 150, 40);
  canvas_set_fill_color("#ffffff");
  canvas_set_font("bold 20px sans-serif");
  canvas_set_text_align("center");
  canvas_fill_text("结束回合", 695, 486);
  canvas_set_text_align("left");

  if state.selected_card >= 0 {
    let card_name: String = list_get(all_cards, state.selected_card).value.name;
    canvas_set_fill_color("#ffd700");
    canvas_set_font("14px sans-serif");
    canvas_set_text_align("center");
      canvas_fill_text(concat("已选择: ", card_name), 400, 355);
      canvas_set_fill_color("#88ff88");
      canvas_set_font("12px sans-serif");
      canvas_fill_text("双击卡牌出牌", 400, 375);
      canvas_set_text_align("left");
  };

  let hand: List<Number> = state.player_hand;
  let hand_len: Number = hand.len;
  let card_w: Number = 100;
  let card_h: Number = 140;
  let spacing: Number = 15;
  let total_w: Number = hand_len * (card_w + spacing) - spacing;
  let start_x: Number = (800 - total_w) / 2;
  let card_y: Number = 390;
  let mut ci: Number = 0;
  while ci < hand_len {
    let cid: Number = list_get(hand, ci).value;
    let cx: Number = start_x + ci * (card_w + spacing);
    let is_selected: Boolean = state.selected_card == cid;
    draw_card_ui(cid, cx, card_y, card_w, card_h, is_selected, false);
    ci = ci + 1;
  };

  canvas_set_fill_color("#333333");
  canvas_fill_rect(0, 540, 800, 60);
  canvas_set_fill_color("#aaaaaa");
  canvas_set_font("13px sans-serif");
  let log_list: List<String> = state.log;
  let mut li: Number = 0;
  while li < log_list.len {
    canvas_fill_text(list_get(log_list, li).value, 20, 560 + li * 18);
    li = li + 1;
  };
}

fn render_game_over() -> Unit {
  render_bg();
  if state.winner == "player" {
    canvas_set_fill_color("#ffd700");
  } else {
    canvas_set_fill_color("#ff4444");
  };
  canvas_set_font("bold 48px sans-serif");
  canvas_set_text_align("center");
  if state.winner == "player" {
    canvas_fill_text("胜利！", 400, 180);
  } else {
    canvas_fill_text("败北...", 400, 180);
  };
  canvas_set_fill_color("#ffffff");
  canvas_set_font("20px sans-serif");
  canvas_fill_text(concat("共", concat(to_string(state.turn), "回合")), 400, 230);
  canvas_set_text_align("left");
  canvas_set_fill_color("#e94560");
  canvas_fill_rect(300, 320, 200, 60);
  canvas_set_fill_color("#ffffff");
  canvas_set_font("bold 28px sans-serif");
  canvas_set_text_align("center");
  canvas_fill_text("重新开始", 400, 358);
  canvas_set_text_align("left");
}

fn render() -> Unit {
  if state.screen == "title" {
    render_title_screen();
  } elif state.screen == "character-select" {
    render_char_select();
  } elif state.screen == "game" {
    render_game_screen();
  } elif state.screen == "game-over" {
    render_game_over();
  };
}

fn start_game(char: String, enemy_char: String, player_hp: Number, enemy_hp: Number) -> Unit {
  let player_ids: List<Number> = shuffle(get_cards_for_char(char));
  let enemy_ids: List<Number> = shuffle(get_cards_for_char(enemy_char));
  let draw_res: DrawResult = draw_n(3, [], player_ids, []);
  state = record_update(state, "screen", "game");
  state = record_update(state, "phase", "player-turn");
  state = record_update(state, "turn", 1);
  state = record_update(state, "player_name", "你");
  state = record_update(state, "player_char", char);
  state = record_update(state, "player_hp", player_hp);
  state = record_update(state, "player_max_hp", player_hp);
  state = record_update(state, "player_mana", 2);
  state = record_update(state, "player_max_mana", 2);
  state = record_update(state, "player_shield", 0);
  state = record_update(state, "player_deck", draw_res.deck);
  state = record_update(state, "player_hand", draw_res.hand);
  state = record_update(state, "player_discard", empty_num_list);
  state = record_update(state, "enemy_name", "敌人");
  state = record_update(state, "enemy_char", enemy_char);
  state = record_update(state, "enemy_hp", enemy_hp);
  state = record_update(state, "enemy_max_hp", enemy_hp);
  state = record_update(state, "enemy_shield", 0);
  state = record_update(state, "enemy_deck", enemy_ids);
  state = record_update(state, "enemy_hand", empty_num_list);
  state = record_update(state, "enemy_discard", empty_num_list);
  state = record_update(state, "selected_card", -1);
  state = record_update(state, "log", ["你的回合！选择卡牌点击敌人区域出牌"]);
  state = record_update(state, "winner", "");
}

fn handle_click(x: Number, y: Number) -> Unit {
  if state.screen == "title" {
    if x >= 300 and x <= 500 and y >= 320 and y <= 380 {
      state = record_update(state, "screen", "character-select");
      render();
    };
  } elif state.screen == "character-select" {
    if x >= 80 and x <= 360 and y >= 100 and y <= 480 {
      start_game("reimu", "marisa", 20, 20);
      render();
    } elif x >= 440 and x <= 720 and y >= 100 and y <= 480 {
      start_game("marisa", "reimu", 18, 20);
      render();
    };
  } elif state.screen == "game" {
    if state.phase == "player-turn" {
      if x >= 620 and x <= 770 and y >= 460 and y <= 500 {
        let new_turn: Number = state.turn + 1;
        state = record_update(state, "turn", new_turn);
        state = record_update(state, "phase", "enemy-turn");
        state = record_update(state, "selected_card", -1);
        state = record_update(state, "player_mana", state.player_max_mana);
        state = record_update(state, "enemy_mana", state.enemy_max_mana);
        state = record_update(state, "player_shield", 0);
        state = record_update(state, "enemy_shield", 0);
        state = record_update(state, "player_max_mana", if state.player_max_mana < 10 { state.player_max_mana + 1 } else { 10 });
        state = record_update(state, "enemy_max_mana", if state.enemy_max_mana < 10 { state.enemy_max_mana + 1 } else { 10 });
        let draw_for_player: DrawResult = draw_one_card(state.player_hand, state.player_deck, state.player_discard);
        let draw_for_enemy: DrawResult = draw_one_card(state.enemy_hand, state.enemy_deck, state.enemy_discard);
        state = record_update(state, "player_hand", draw_for_player.hand);
        state = record_update(state, "player_deck", draw_for_player.deck);
        state = record_update(state, "player_discard", draw_for_player.discard);
        state = record_update(state, "enemy_hand", draw_for_enemy.hand);
        state = record_update(state, "enemy_deck", draw_for_enemy.deck);
        state = record_update(state, "enemy_discard", draw_for_enemy.discard);
        state = record_update(state, "log", add_log(state.log, "--- 敌人回合 ---"));
        render();
        enemy_turn_ai();
        if state.screen != "game-over" {
          state = record_update(state, "phase", "player-turn");
          state = record_update(state, "log", add_log(state.log, "--- 你的回合 ---"));
        };
        render();
      } elif y >= 390 and y <= 530 {
        let hand: List<Number> = state.player_hand;
        let hand_len: Number = hand.len;
        let card_w: Number = 100;
        let spacing: Number = 15;
        let total_w: Number = hand_len * (card_w + spacing) - spacing;
        let start_x: Number = (800 - total_w) / 2;
        let ci: Number = (x - start_x) / (card_w + spacing);
        if ci >= 0 and ci < hand_len {
          let cid: Number = list_get(hand, ci).value;
          state = record_update(state, "selected_card", cid);
          render();
        };
      } else {
        if state.selected_card >= 0 {
          state = record_update(state, "selected_card", -1);
          render();
        };
      };
    };
  } elif state.screen == "game-over" {
    if x >= 300 and x <= 500 and y >= 320 and y <= 380 {
      state = record_update(state, "screen", "title");
      render();
    };
  };
}

fn handle_dblclick(x: Number, y: Number) -> Unit {
  if state.screen == "game" and state.phase == "player-turn" {
    if y >= 390 and y <= 530 {
      let hand: List<Number> = state.player_hand;
      let hand_len: Number = hand.len;
      let card_w: Number = 100;
      let spacing: Number = 15;
      let total_w: Number = hand_len * (card_w + spacing) - spacing;
      let start_x: Number = (800 - total_w) / 2;
      let ci: Number = (x - start_x) / (card_w + spacing);
      if ci >= 0 and ci < hand_len {
        try_play_card(ci);
        render();
      };
    };
  };
}

fn handle_hover(x: Number, y: Number) -> Unit {
  if state.screen == "title" {
    if x >= 300 and x <= 500 and y >= 320 and y <= 380 {
      canvas_set_cursor("pointer")
    } else {
      canvas_set_cursor("default")
    }
  } elif state.screen == "character-select" {
    if x >= 80 and x <= 360 and y >= 100 and y <= 480 {
      canvas_set_cursor("pointer")
    } elif x >= 440 and x <= 720 and y >= 100 and y <= 480 {
      canvas_set_cursor("pointer")
    } else {
      canvas_set_cursor("default")
    }
  } elif state.screen == "game" {
    if state.phase == "player-turn" {
      if x >= 620 and x <= 770 and y >= 460 and y <= 500 {
        canvas_set_cursor("pointer")
      } elif y >= 390 and y <= 530 {
        canvas_set_cursor("pointer")
      } else {
        canvas_set_cursor("default")
      }
    } else {
      canvas_set_cursor("default")
    }
  } elif state.screen == "game-over" {
    if x >= 300 and x <= 500 and y >= 320 and y <= 380 {
      canvas_set_cursor("pointer")
    } else {
      canvas_set_cursor("default")
    }
  } else {
    canvas_set_cursor("default")
  }
}

fn get_char_img(char: String) -> Number {
  if char == "reimu" { reimu_img } else { marisa_img }
}

fn main() -> Unit {
  reimu_img = canvas_load_image("reimu.png");
  marisa_img = canvas_load_image("marisa.png");
  render();
  canvas_on_click(handle_click);
  canvas_on_drag(handle_hover);
  canvas_on_dblclick(handle_dblclick);
}
